NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/clinic_appointment_system?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=*
SERVER_PUBLIC_URL=https://your-smart-clinic-api.onrender.com
ADMIN_EMAIL=admin@clinic.com
ADMIN_PASSWORD=replace_with_secure_admin_password
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=0710000000
APPOINTMENT_FEE_AMOUNT=2500
APPOINTMENT_FEE_CURRENCY=LKR
PAYMENT_DUE_WINDOW_MINUTES=30
PAYPAL_MODE=sandbox
PAYPAL_SETTLEMENT_CURRENCY=USD
PAYPAL_LKR_PER_USD=300
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
